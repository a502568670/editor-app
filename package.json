{
  "name": "jzl_editor",
  "version": "0.1.4",
  "private": true,
  "description": "极致了编辑器",
  "author": "jzl_editor",
  "scripts": {
    "serve": "vue-cli-service serve",
    "build": "vue-cli-service build",
    "lint": "vue-cli-service lint",
    "electron:build": "vue-cli-service electron:build",
    "electron:build_mac": "cross-env PYTHON_PATH=/usr/bin/python3 vue-cli-service electron:build",
    "electron:serve": "cross-env BACKEND_URL=http://127.0.0.1:8000 VERBOSE=true vue-cli-service electron:serve",
    "electron:serve-prod": "cross-env BACKEND_URL=http://47.96.22.8:8006 vue-cli-service electron:serve",
    "postinstall": "electron-builder install-app-deps",
    "postuninstall": "electron-builder install-app-deps"
  },
  "main": "background.js",
  "dependencies": {
    "@element-plus/icons-vue": "^2.1.0",
    "@mayasabha/ckeditor4-vue3": "^1.0.9",
    "@wangeditor/editor-for-vue": "^5.1.12",
    "axios": "^1.7.7",
    "core-js": "^3.30.2",
    "dotenv": "^16.5.0",
    "electron-log": "^4.4.8",
    "electron-updater": "^6.6.2",
    "element-plus": "^2.3.4",
    "js-cookie": "^3.0.5",
    "lucide-vue-next": "^0.509.0",
    "qs": "^6.14.0",
    "vue": "^3.3.4",
    "vue-router": "^4.2.1",
    "vue-ueditor-wrap": "^3.0.8",
    "vuex": "^4.0.2"
  },
  "devDependencies": {
    "@babel/core": "7.21.8",
    "@babel/eslint-parser": "7.21.8",
    "@esbuild-plugins/node-modules-polyfill": "^0.2.2",
    "@iconify-json/ep": "^1.1.10",
    "@vue/cli-plugin-babel": "~5.0.8",
    "@vue/cli-plugin-eslint": "~5.0.8",
    "@vue/cli-service": "^5.0.8",
    "@vue/compiler-sfc": "^3.3.4",
    "autoprefixer": "^10.4.14",
    "cross-env": "^7.0.3",
    "electron": "24.3.1",
    "electron-devtools-installer": "^3.2.0",
    "eslint": "^8.41.0",
    "eslint-plugin-vue": "^9.13.0",
    "postcss": "^8.4.23",
    "tailwindcss": "^3.3.2",
    "unplugin-icons": "^0.16.1",
    "unplugin-vue-components": "^0.24.1",
    "vue-cli-plugin-electron-builder": "~2.1.1"
